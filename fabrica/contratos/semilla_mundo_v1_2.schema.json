{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-dm.local/schemas/semilla_mundo_v1_2.schema.json",
  "title": "Semilla de mundo v1.2",
  "type": "object",
  "additionalProperties": false,
  "required": ["tipo_documento", "version", "origen", "familia_experiencia", "nucleo_distintivo", "promesa_jugable", "papel_jugador", "orientacion", "experiencia_jugable", "aportaciones_personales", "limites_contenido", "libertad_creativa", "notas_para_codex"],
  "properties": {
    "tipo_documento": { "const": "semilla_mundo" },
    "version": { "const": "1.2" },
    "origen": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generado_por", "confirmada_por_usuario"],
      "properties": {
        "generado_por": { "const": "pregenerador" },
        "confirmada_por_usuario": { "type": "boolean" }
      }
    },
    "familia_experiencia": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generos", "subgeneros"],
      "properties": {
        "generos": { "type": "array", "minItems": 1, "maxItems": 3, "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 80 } },
        "subgeneros": { "type": "array", "maxItems": 4, "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 80 } }
      }
    },
    "nucleo_distintivo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fantasia_jugador", "situacion_semilla", "foco_central", "friccion_principal", "tension_tematica", "motivos_materiales"],
      "properties": {
        "fantasia_jugador": { "type": "string", "minLength": 20, "maxLength": 240 },
        "situacion_semilla": { "type": "string", "minLength": 20, "maxLength": 320 },
        "foco_central": { "type": "string", "minLength": 10, "maxLength": 200 },
        "friccion_principal": { "type": "string", "minLength": 20, "maxLength": 280 },
        "tension_tematica": { "type": "string", "minLength": 10, "maxLength": 240 },
        "motivos_materiales": { "type": "array", "minItems": 3, "maxItems": 5, "uniqueItems": true, "items": { "type": "string", "minLength": 2, "maxLength": 100 } }
      }
    },
    "promesa_jugable": { "type": "string", "minLength": 10, "maxLength": 240 },
    "papel_jugador": {
      "type": "object",
      "additionalProperties": false,
      "required": ["descripcion", "limitacion_significativa"],
      "properties": {
        "descripcion": { "type": ["string", "null"], "maxLength": 120 },
        "limitacion_significativa": { "type": ["string", "null"], "maxLength": 160 }
      }
    },
    "orientacion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ejes"],
      "properties": {
        "ejes": {
          "type": "array",
          "maxItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["nombre", "intensidad", "interpretacion"],
            "properties": {
              "nombre": { "type": "string", "minLength": 1, "maxLength": 60 },
              "intensidad": { "enum": ["bajo", "medio", "alto", "libre"] },
              "interpretacion": { "type": "string", "minLength": 1, "maxLength": 180 }
            }
          }
        }
      }
    },
    "experiencia_jugable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resumen_usuario", "prioridades", "ritmo", "densidad", "funcion_objetos", "funcion_deducciones", "naturaleza_decisiones", "severidad_error", "horizonte_consecuencias"],
      "properties": {
        "resumen_usuario": { "type": "string", "minLength": 20, "maxLength": 240 },
        "prioridades": {
          "type": "array",
          "minItems": 2,
          "maxItems": 3,
          "uniqueItems": true,
          "items": { "enum": ["sobrevivir", "proteger", "descubrir", "demostrar", "escapar", "perseguir", "negociar", "explorar", "recuperar", "decidir_lealtades"] }
        },
        "ritmo": { "enum": ["pausado", "variable", "urgente", "opresivo"] },
        "densidad": { "enum": ["directa", "equilibrada", "intensa"] },
        "funcion_objetos": { "enum": ["condicionar_capacidades", "salvar_o_destruir", "abrir_o_cerrar_rutas", "conceder_influencia", "revelar_y_comprometer"] },
        "funcion_deducciones": { "enum": ["reconstruir_verdad", "leer_peligro", "habilitar_confrontacion", "descubrir_ruta", "alterar_relaciones"] },
        "naturaleza_decisiones": { "enum": ["coste_moral_social", "riesgo_fisico_inmediato", "posicion_persecucion", "lealtad_confianza", "exploracion_renuncia"] },
        "severidad_error": { "enum": ["desgaste", "perdida_relevante", "irreversible", "letal"] },
        "horizonte_consecuencias": { "enum": ["inmediato", "cercano", "diferido", "mixto"] }
      }
    },
    "aportaciones_personales": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tipo", "descripcion", "prioridad"],
        "properties": {
          "tipo": { "enum": ["idea", "ambiente", "epoca", "lugar", "personaje", "relacion", "objeto", "profesion", "referencia", "otro"] },
          "descripcion": { "type": "string", "minLength": 1, "maxLength": 240 },
          "prioridad": { "enum": ["obligatorio", "preferencia"] }
        }
      }
    },
    "limites_contenido": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prohibido", "solo_fuera_de_plano", "moderado"],
      "properties": {
        "prohibido": { "$ref": "#/$defs/listaLimites" },
        "solo_fuera_de_plano": { "$ref": "#/$defs/listaLimites" },
        "moderado": { "$ref": "#/$defs/listaLimites" }
      }
    },
    "libertad_creativa": { "enum": ["guiada", "equilibrada", "alta_sorpresa"] },
    "notas_para_codex": { "type": "array", "maxItems": 6, "items": { "type": "string", "minLength": 1, "maxLength": 240 } }
  },
  "$defs": {
    "listaLimites": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 200 } }
  }
}
