# No API key is required for the default Corto guiado demo.
# Add one provider only if you want to experiment with Libre asistido.

GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Optional OpenRouter attribution. Leave blank for local evaluation.
OPENROUTER_SITE_URL=

# Privacy-safe default. Set to true only for deliberate local debugging.
LOG_PROMPTS_COMPLETS=false
